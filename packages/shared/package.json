{
  "name": "@carswash/shared",
  "version": "0.0.0",
  "private": true,
  "description": "Shared TS package: generated OpenAPI client + shared enums/constants.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
