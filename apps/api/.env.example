# API (FastAPI) environment. Copy to apps/api/.env and fill in.
# These are secrets — never commit the real .env (it is git-ignored).

# Pooled connection (Supavisor, port 6543) — used by the app at runtime.
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:6543/postgres

# Direct connection (port 5432) — used by Alembic migrations.
DIRECT_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# Secret used to verify Supabase-issued JWTs.
SUPABASE_JWT_SECRET=your-jwt-secret

# Supabase service-role key — server-side only, never exposed to the web.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Deployment environment: development | staging | production.
ENV=development
