# API (FastAPI) environment. Copy to apps/api/.env and fill in.
# These are secrets — never commit the real .env (it is git-ignored).
# Names match what Supabase/Vercel provide (pulled via `vercel env pull`).

# Pooled connection (Supavisor transaction pooler) — used by the app at runtime.
# Prepared statements are disabled for this pooler; SSL is required.
POSTGRES_URL=postgres://postgres.your-project:password@aws-region.pooler.supabase.com:6543/postgres

# Direct connection (port 5432) — used by Alembic migrations (never the pooler).
POSTGRES_URL_NON_POOLING=postgres://postgres.your-project:password@aws-region.pooler.supabase.com:5432/postgres

# Secret used to verify Supabase-issued JWTs (Phase 2+).
SUPABASE_JWT_SECRET=your-jwt-secret

# Supabase service-role key — server-side only, never exposed to the web (Phase 2+).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Deployment environment: development | staging | production.
ENV=development
