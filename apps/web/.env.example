# Web (Next.js) environment. Copy to apps/web/.env.local and fill in.
# Only NEXT_PUBLIC_* values reach the browser. Never put secrets here
# (no service-role key on the web side — see CONVENTIONS.md §7).

# Supabase project URL (used by the JS client for auth + realtime).
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase anon (public) key — safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Base URL of the FastAPI backend.
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
