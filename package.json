{
  "name": "carswash",
  "version": "0.0.0",
  "private": true,
  "description": "Multi-tenant SaaS for car-wash networks — polyglot monorepo (Next 16 web + FastAPI api).",
  "packageManager": "pnpm@10.34.3",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "prepare": "lefthook install",
    "dev:web": "pnpm --filter web dev",
    "dev:api": "uv run --directory apps/api uvicorn app.main:app --reload",
    "build:web": "pnpm --filter web build",
    "lint": "biome check .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "typecheck:web": "pnpm --filter web exec tsc --noEmit",
    "typecheck:shared": "pnpm --filter @carswash/shared exec tsc --noEmit",
    "typecheck": "pnpm run typecheck:web && pnpm run typecheck:shared",
    "test:web": "pnpm --filter web test",
    "lint:api": "uv run --directory apps/api ruff check .",
    "format:api:check": "uv run --directory apps/api ruff format --check .",
    "typecheck:api": "uv run --directory apps/api mypy",
    "test:api": "uv run --directory apps/api pytest",
    "openapi:export": "uv run --directory apps/api python -m app.export_openapi > packages/shared/openapi/schema.json",
    "openapi:generate": "pnpm run openapi:export && pnpm --filter @carswash/shared run generate:types"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "lefthook": "^2.1.9"
  }
}
